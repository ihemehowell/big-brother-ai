{
  "name": "big-brother-ai",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:web": "pnpm --filter @bb/web dev",
    "dev:server": "pnpm --filter @bb/server dev",
    "build:web": "pnpm --filter @bb/web build",
    "build:server": "pnpm --filter @bb/server build",
    "build": "pnpm build:web && pnpm build:server",
    "start": "pnpm --filter @bb/server start",
    "db:generate": "pnpm --filter @bb/server db:generate",
    "db:migrate": "pnpm --filter @bb/server db:migrate",
    "db:studio": "pnpm --filter @bb/server db:studio",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}